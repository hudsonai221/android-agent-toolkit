#!/data/data/com.termux/files/usr/bin/bash
# Android Agent Toolkit — CLI entrypoint
# https://github.com/hudsonai221/android-agent-toolkit

set -euo pipefail

AAT_DIR="$(cd "$(dirname "$0")" && pwd)"
AAT_VERSION="0.2.0"

usage() {
  cat <<EOF
Android Agent Toolkit v${AAT_VERSION}
Operational tooling for OpenClaw on Android.

Usage: aat <command> [options]

Commands:
  status     Combined system dashboard (gateway, watchdog, backups, resources)
  logs       Unified log viewer (gateway, watchdog, cron)
  health     Run health checks (gateway, RAM, storage, battery)
  watchdog   Monitor and auto-restart gateway
  backup     Backup workspace and config
  bench      Benchmark device compatibility and performance
  version    Show version

Options:
  -h, --help    Show this help

https://github.com/hudsonai221/android-agent-toolkit
EOF
}

case "${1:-}" in
  status)
    shift
    exec bash "$AAT_DIR/commands/status.sh" "$@"
    ;;
  logs)
    shift
    exec bash "$AAT_DIR/commands/logs.sh" "$@"
    ;;
  health)
    shift
    exec bash "$AAT_DIR/commands/health.sh" "$@"
    ;;
  watchdog)
    shift
    exec bash "$AAT_DIR/commands/watchdog.sh" "$@"
    ;;
  backup)
    shift
    exec bash "$AAT_DIR/commands/backup.sh" "$@"
    ;;
  bench)
    shift
    exec bash "$AAT_DIR/commands/bench.sh" "$@"
    ;;
  version|--version|-v)
    echo "aat v${AAT_VERSION}"
    ;;
  help|--help|-h|"")
    usage
    ;;
  *)
    echo "Error: unknown command '$1'" >&2
    echo "Run 'aat help' for usage." >&2
    exit 1
    ;;
esac
